package com.creysvpn.app;

import android.content.Intent;
import android.content.SharedPreferences;
import android.os.Bundle;
import android.widget.Button;
import android.widget.EditText;
import android.widget.TextView;
import androidx.appcompat.app.AppCompatActivity;
import com.google.firebase.database.DataSnapshot;
import com.google.firebase.database.DatabaseError;
import com.google.firebase.database.DatabaseReference;
import com.google.firebase.database.FirebaseDatabase;
import com.google.firebase.database.ValueEventListener;

public class KeyActivity extends AppCompatActivity {

    private static final String PREFS = "creysvpn_prefs";
    private static final String KEY_ACTIVATED = "key_activated";
    private static final String KEY_EXPIRES = "key_expires";

    private EditText etKey;
    private Button btnActivate;
    private TextView tvStatus;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);

        // Если ключ уже активирован и не истёк — сразу в главное меню
        if (isKeyValid()) {
            goToMain();
            return;
        }

        setContentView(R.layout.activity_key);
        etKey = findViewById(R.id.etKey);
        btnActivate = findViewById(R.id.btnActivate);
        tvStatus = findViewById(R.id.tvStatus);

        btnActivate.setOnClickListener(v -> {
            String key = etKey.getText().toString().trim().toUpperCase();
            if (key.isEmpty()) {
                tvStatus.setText("Введи ключ");
                return;
            }
            activateKey(key);
        });
    }

    private void activateKey(String key) {
        btnActivate.setEnabled(false);
        tvStatus.setText("Проверка...");

        String myDeviceId = DeviceIdGenerator.getDeviceId(this);

        DatabaseReference ref = FirebaseDatabase.getInstance()
                .getReference("keys")
                .child(key);

        ref.addListenerForSingleValueEvent(new ValueEventListener() {
            @Override
            public void onDataChange(DataSnapshot snap) {

                // Ключ не существует в базе
                if (!snap.exists()) {
                    tvStatus.setText("Ключ не найден");
                    btnActivate.setEnabled(true);
                    return;
                }

                // Читаем поля — используем Object чтобы не падать на пустых строках
                Object activatedRaw = snap.child("activated").getValue();
                Object adminRaw = snap.child("admin").getValue();
                Object typeRaw = snap.child("type").getValue();
                Object deviceIdRaw = snap.child("device_id").getValue();
                Object expiresRaw = snap.child("expires_at").getValue();

                // Конвертируем в нормальные типы
                boolean activated = activatedRaw != null && Boolean.TRUE.equals(activatedRaw);
                boolean isAdmin = adminRaw != null && Boolean.TRUE.equals(adminRaw);
                String type = (typeRaw != null && !typeRaw.toString().isEmpty()) ? typeRaw.toString() : "day";
                String boundDevice = (deviceIdRaw != null && !deviceIdRaw.toString().isEmpty() && !deviceIdRaw.toString().equals("null")) ? deviceIdRaw.toString() : null;

                // Получаем expires_at — может быть Long, Number или пустым
                Long expiresAt = null;
                if (expiresRaw instanceof Long) {
                    expiresAt = (Long) expiresRaw;
                } else if (expiresRaw instanceof Number) {
                    expiresAt = ((Number) expiresRaw).longValue();
                }

                // Ключ уже активирован на ДРУГОМ устройстве — отказ
                if (activated && boundDevice != null && !boundDevice.equals(myDeviceId)) {
                    tvStatus.setText("Ключ уже используется");
                    btnActivate.setEnabled(true);
                    return;
                }

                // Ключ уже активирован на ЭТОМ устройстве — просто проверяем срок
                if (activated && myDeviceId.equals(boundDevice)) {
                    if (isAdmin) {
                        // Админский ключ — вечный
                        saveAndGo(Long.MAX_VALUE);
                    } else if (expiresAt != null && expiresAt > System.currentTimeMillis()) {
                        // Ключ ещё действует
                        saveAndGo(expiresAt);
                    } else {
                        tvStatus.setText("Срок ключа истёк");
                        btnActivate.setEnabled(true);
                    }
                    return;
                }

                // Ключ ещё не активирован — активируем
                long newExpiresAt;
                if (isAdmin) {
                    newExpiresAt = Long.MAX_VALUE;
                } else {
                    long now = System.currentTimeMillis();
                    if ("month".equals(type)) {
                        newExpiresAt = now + 30L * 24 * 60 * 60 * 1000;
                    } else if ("week".equals(type)) {
                        newExpiresAt = now + 7L * 24 * 60 * 60 * 1000;
                    } else {
                        // day — по умолчанию
                        newExpiresAt = now + 24L * 60 * 60 * 1000;
                    }
                }

                final long finalExpires = newExpiresAt;

                // Записываем в Firebase
                ref.child("activated").setValue(true);
                ref.child("device_id").setValue(myDeviceId);
                ref.child("expires_at").setValue(finalExpires)
                        .addOnSuccessListener(unused -> {
                            saveAndGo(finalExpires);
                        })
                        .addOnFailureListener(e -> {
                            tvStatus.setText("Ошибка записи в базу");
                            btnActivate.setEnabled(true);
                        });
            }

            @Override
            public void onCancelled(DatabaseError error) {
                tvStatus.setText("Нет соединения с сервером");
                btnActivate.setEnabled(true);
            }
        });
    }

    private void saveAndGo(long expiresAt) {
        getSharedPreferences(PREFS, MODE_PRIVATE).edit()
                .putBoolean(KEY_ACTIVATED, true)
                .putLong(KEY_EXPIRES, expiresAt)
                .apply();
        goToMain();
    }

    private boolean isKeyValid() {
        SharedPreferences prefs = getSharedPreferences(PREFS, MODE_PRIVATE);
        if (!prefs.getBoolean(KEY_ACTIVATED, false)) return false;
        long expires = prefs.getLong(KEY_EXPIRES, 0);
        return expires == Long.MAX_VALUE || expires > System.currentTimeMillis();
    }

    private void goToMain() {
        startActivity(new Intent(this, MainActivity.class));
        finish();
    }
}
